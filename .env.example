# LLM Configuration
LLM_API_KEY=your_gemini_or_qwen_key_here
LLM_PROVIDER=gemini

# Optional: NewsAPI
NEWSAPI_KEY=your_newsapi_key_here

# LangSmith Tracing (optional - for LangGraph observability)
# Get your API key at https://smith.langchain.com/
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=triangulate  # Optional: defaults to "default"

# Database
DATABASE_PATH=./triangulate.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/triangulate.log
